#!/bin/sh
#
# pre-push hook — automatyczne czyszczenie przed pushem na remote.
#
# Co robi:
#   1. Blokuje branche z zabronionym słowem w nazwie (np. "claude")
#   2. Blokuje commity z zabronionym autorem/committerem
#   3. Zamazuje LECTURER_SERVER (prawdziwy IP:port → placeholder)
#   4. Odpala przed_zajeciami.py (czyści outputy, resetuje stuby, zwija podpowiedzi)
#   5. Jeśli cokolwiek się zmieniło → commituje fix i blokuje push
#      (żebyś zobaczył co się zmieniło i spróbował push ponownie)
#
# Activate with: git config core.hooksPath .githooks

BLOCKED_EMAILS="kamil.jedryczek@airslate.com"
BLOCKED_NAMES="claude"
BLOCKED_BRANCH_PATTERNS="claude"
PLACEHOLDER='http://ADRES_SERWERA:PORT'

# ── CHECK 1: Branch name + Author / committer ───────────────────────

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi

    # -- Branch name --
    ref_lower=$(echo "$local_ref" | tr '[:upper:]' '[:lower:]')
    for pattern in $BLOCKED_BRANCH_PATTERNS; do
        case "$ref_lower" in
            *"$pattern"*)
                echo "BLOCKED: branch '$local_ref' contains '$pattern'"
                echo "Rename your branch: git branch -m <new-name>"
                exit 1
                ;;
        esac
    done

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    for commit in $(git rev-list "$range" 2>/dev/null); do
        author_name=$(git log -1 --format='%an' "$commit")
        author_email=$(git log -1 --format='%ae' "$commit")
        committer_name=$(git log -1 --format='%cn' "$commit")
        committer_email=$(git log -1 --format='%ce' "$commit")

        for email in $BLOCKED_EMAILS; do
            if [ "$author_email" = "$email" ] || [ "$committer_email" = "$email" ]; then
                echo "BLOCKED: commit $commit has email $email"
                echo "Fix: git commit --amend --author='NXTRSS <kamillo_j@yahoo.com>'"
                exit 1
            fi
        done

        for name in $BLOCKED_NAMES; do
            a_lower=$(echo "$author_name" | tr '[:upper:]' '[:lower:]')
            c_lower=$(echo "$committer_name" | tr '[:upper:]' '[:lower:]')
            if [ "$a_lower" = "$name" ] || [ "$c_lower" = "$name" ]; then
                echo "BLOCKED: commit $commit has author/committer '$name'"
                echo "Fix: git commit --amend --author='NXTRSS <kamillo_j@yahoo.com>'"
                exit 1
            fi
        done
    done
done

# ── AUTO-FIX 1: Zamazaj LECTURER_SERVER ──────────────────────────────
#
# Zamienia prawdziwy adres (np. http://192.168.x.x:XXXX)
# na placeholder http://ADRES_SERWERA:PORT.
# Obsługuje zarówno .py (normalne cudzysłowy) jak i .ipynb (escaped \").

FIXED_FILES=$(python3 -c "
import re

placeholder = '${PLACEHOLDER}'
files_fixed = []

for path in ['utils.py', '_build_fc_notebook.py', 'Function_Calling.ipynb']:
    try:
        text = open(path, encoding='utf-8').read()
    except FileNotFoundError:
        continue
    if 'ADRES_SERWERA' in text:
        continue

    new = re.sub(
        r'((?:LECTURER_SERVER|lecturer_server)\s*=\s*)(\\\\?\")http://[^\"\\\\]+(\\\\?\")',
        rf'\g<1>\g<2>{placeholder}\g<3>',
        text,
    )
    if new != text:
        open(path, 'w', encoding='utf-8').write(new)
        files_fixed.append(path)

print(' '.join(files_fixed))
")

# ── AUTO-FIX 2: przed_zajeciami.py ──────────────────────────────────
#
# Czyści outputy, resetuje stuby, zwija podpowiedzi.

PRZED_ZAJECIAMI=""
if [ -f "przed_zajeciami.py" ]; then
    echo "[pre-push] Uruchamiam przed_zajeciami.py..."
    python3 przed_zajeciami.py 2>&1 | sed 's/^/  /'
    PRZED_ZAJECIAMI="tak"
fi

# ── COMMIT jeśli cokolwiek się zmieniło ──────────────────────────────

CHANGED_FILES=$(git diff --name-only)
if [ -n "$CHANGED_FILES" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  pre-push: poprawiłem pliki przed wysłaniem na remote   ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""

    if [ -n "$FIXED_FILES" ]; then
        echo "  Zamazano LECTURER_SERVER w: $FIXED_FILES"
    fi
    if [ -n "$PRZED_ZAJECIAMI" ]; then
        echo "  Uruchomiono przed_zajeciami.py (outputy, stuby, podpowiedzi)"
    fi

    echo ""
    echo "  Zmiany:"
    git diff --stat | sed 's/^/    /'
    echo ""

    # Commituj poprawki — TYLKO zmienione tracked pliki (nie -A!)
    # -z + xargs -0 obsługuje polskie znaki w nazwach plików
    git diff -z --name-only | xargs -0 git add --
    GIT_COMMITTER_NAME="NXTRSS" GIT_COMMITTER_EMAIL="kamillo_j@yahoo.com" \
        git commit --author="NXTRSS <kamillo_j@yahoo.com>" \
        -m "auto: sanitize LECTURER_SERVER + przed_zajeciami.py" \
        --quiet

    echo "  ✓ Commitnąłem poprawki."
    echo ""
    echo "  Uruchom ponownie:  git push"
    echo ""
    exit 1
fi
